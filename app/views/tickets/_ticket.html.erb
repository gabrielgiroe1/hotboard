<%= turbo_frame_tag ticket do %>
<div id="<%= dom_id ticket %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Title:</strong>
    <%= ticket.title %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Description:</strong>
    <%= ticket.description %>
  </div>
</div>
  <%= link_to "Edit", edit_ticket_path(ticket), class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
  <div class="inline-block ml-2">
    <%= button_to "Destroy this ticket", ticket, method: :delete, class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 text-white bg-red-600 hover:bg-red-500 font-medium cursor-pointer", data: { turbo_confirm: "Are you sure?", turbo_frame: "_top" } %>
  </div>
<% end %>
